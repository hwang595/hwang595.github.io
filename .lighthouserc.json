{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": [
        "/",
        "/publications/",
        "/group/",
        "/research/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.95
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.75
          }
        ]
      }
    }
  }
}
